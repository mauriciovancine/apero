map_bamges_bacias <- tm_shape(lim_bamges) +
  tm_polygons() +
  tm_shape(micro_cor_ba) +
  tm_polygons(col = "orange") +
  tm_shape(cor_ba) +
  tm_fill(col = "forestgreen") +
  tm_shape(imoveis[lim_bamges, ]) +
  tm_fill(col = "gray30", alpha = .7) +
  tm_graticules(lines = FALSE, labels.size = .8) +
  tm_compass(size = 3) +
  tm_scale_bar(text.size = .8) +
  tm_add_legend(type = "fill", 
                labels = c("Bacias total", "Bacias corredores", "Corredores", "Imóveis"),
                col = c("gray", "orange", "forestgreen", "gray30"),
                border.col = "gray40",
                size = 5,
                title = "Legenda") +
  tm_layout(title = "BAMGES",
            legend.title.size = 1.8,
            legend.title.fontface = "bold",
            legend.text.size = 1)
