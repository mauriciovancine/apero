mapbiomas

### bamges ----
estradas_bamges <- sf::st_intersection(estradas_filter, lim_bamges)
estradas_bamges

mapbiomas_bamges <- mapbiomas %>% 
  terra::crop(terra::vect(lim_bamges)) %>% 
  terra::mask(terra::vect(lim_bamges))
mapbiomas_bamges

forest_bamges <- mapbiomas_bamges %in% c(3, 4) %>% 
  terra::mask(terra::vect(lim_bamges))
forest_bamges[forest_bamges == 0] <- NA

forest_bamges_vector <- as.polygons(forest_bamges)
forest_bamges_vector

forest_bamges_vector_sf <- sf::st_as_sf(forest_bamges_vector) %>% 
  sf::st_cast("POLYGON") %>% 
  dplyr::mutate(area_ha = as.numeric(sf::st_area(.)/1e4)) %>% 
  dplyr::filter(area_ha >= 60)
forest_bamges_vector_sf

forest_bamges_vector_sf_estradas <- forest_bamges_vector_sf[estradas_bamges, ]
forest_bamges_vector_sf_estradas

forest_bamges_vector_sf_estradas_rast <- fasterize::fasterize(
  sf = forest_bamges_vector_sf_estradas, 
  raster = fasterize::raster(forest_bamges_vector_sf_estradas, res = 90/3600/30),
  field = "area_ha") %>% 
  terra::rast()
forest_bamges_vector_sf_estradas_rast

forest_bamges_vector_sf_estradas_rast_bin <- terra::ifel(is.na(forest_bamges_vector_sf_estradas_rast), 0, 1) %>% 
  terra::mask(vect(lim_bamges))

plot(log10(forest_bamges_vector_sf_estradas_rast))
plot(forest_bamges_vector_sf_estradas_rast_bin)
plot(estradas_bamges$geometry, add = TRUE)

terra::writeRaster(forest_bamges_vector_sf_estradas_rast, "03_resultados/12_caracterizao_ambiental/barreiras/forest_bamges_vector_sf_estradas_rast.tif", overwrite = TRUE)
terra::writeRaster(forest_bamges_vector_sf_estradas_rast_bin, "03_resultados/12_caracterizao_ambiental/barreiras/forest_bamges_vector_sf_estradas_rast_bin.tif", overwrite = TRUE)
